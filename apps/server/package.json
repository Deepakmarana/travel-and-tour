{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "cd ../.. && bun run --watch --env-file apps/server/.env apps/server/src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@travel-and-tour/auth": "workspace:*",
    "@travel-and-tour/db": "workspace:*",
    "@travel-and-tour/env": "workspace:*",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "stripe": "^22.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@travel-and-tour/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
